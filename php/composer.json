{
    "name": "apstndb/spanvalue",
    "description": "Format Cloud Spanner types and column values (human-readable, SQL literals, spanner-cli)",
    "version": "0.1.0-alpha.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "apstndb"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-intl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "classmap": [
            "src/"
        ],
        "files": [
            "src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Apstndb\\SpanValue\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
